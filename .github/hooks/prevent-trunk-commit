#!/bin/bash
# ============================================================================
# Pre-commit Hook: Prevent Commits to Trunk Branches
# ============================================================================
#
# This hook prevents accidentally committing directly to trunk/main branches.
# Trunk branches should only receive commits via pull requests.
#
# Installation:
#   1. Copy to .git/hooks/pre-commit:
#      cp .github/hooks/prevent-trunk-commit .git/hooks/pre-commit
#   2. Make executable:
#      chmod +x .git/hooks/pre-commit
#
# With Husky (recommended):
#   husky install
#   npx husky add .husky/pre-commit '.github/hooks/prevent-trunk-commit'
#
# ============================================================================

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# ============================================================================
# CONFIGURATION
# ============================================================================

# List of trunk branches (adjust for your project)
TRUNK_BRANCHES=(
    "main"
    "master"
    "trunk"
    "develop"
    "production"
    "release"
)

# ============================================================================
# GET CURRENT BRANCH
# ============================================================================

CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)

if [ -z "$CURRENT_BRANCH" ]; then
    echo -e "${RED}✗ Error: Could not determine current branch${NC}"
    exit 1
fi

# ============================================================================
# CHECK IF CURRENT BRANCH IS A TRUNK BRANCH
# ============================================================================

IS_TRUNK=false

for trunk in "${TRUNK_BRANCHES[@]}"; do
    if [ "$CURRENT_BRANCH" = "$trunk" ]; then
        IS_TRUNK=true
        break
    fi
done

# ============================================================================
# PREVENT COMMIT IF ON TRUNK BRANCH
# ============================================================================

if [ "$IS_TRUNK" = true ]; then
    echo ""
    echo -e "${RED}╔════════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${RED}║          ✗ CANNOT COMMIT DIRECTLY TO TRUNK BRANCH              ║${NC}"
    echo -e "${RED}╚════════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "${YELLOW}Current branch: ${BLUE}${CURRENT_BRANCH}${NC}"
    echo ""
    echo -e "${YELLOW}This is a trunk/main branch and should only receive commits via pull requests.${NC}"
    echo ""
    echo -e "${GREEN}How to fix:${NC}"
    echo ""
    echo -e "  1. ${BLUE}Stash your changes:${NC}"
    echo "     ${BLUE}git stash${NC}"
    echo ""
    echo -e "  2. ${BLUE}Switch to a feature branch:${NC}"
    echo "     ${BLUE}git checkout -b feature/your-feature-name${NC}"
    echo "     ${BLUE}# Or use git switch for Git 2.23+:${NC}"
    echo "     ${BLUE}git switch -c feature/your-feature-name${NC}"
    echo ""
    echo -e "  3. ${BLUE}Restore your changes:${NC}"
    echo "     ${BLUE}git stash pop${NC}"
    echo ""
    echo -e "  4. ${BLUE}Commit and push:${NC}"
    echo "     ${BLUE}git add .${NC}"
    echo "     ${BLUE}git commit -m 'Your commit message'${NC}"
    echo "     ${BLUE}git push -u origin feature/your-feature-name${NC}"
    echo ""
    echo -e "  5. ${BLUE}Create a pull request on GitHub/GitLab${NC}"
    echo ""
    echo -e "${GREEN}Branch naming convention:${NC}"
    echo ""
    echo "  feature/  - New features"
    echo "  fix/      - Bug fixes"
    echo "  refactor/ - Code refactoring"
    echo "  test/     - Testing improvements"
    echo "  docs/     - Documentation"
    echo "  chore/    - Maintenance tasks"
    echo "  perf/     - Performance improvements"
    echo "  ci/       - CI/CD changes"
    echo ""
    echo -e "${GREEN}Examples:${NC}"
    echo ""
    echo "  feature/user-authentication"
    echo "  fix/email-validation-crash"
    echo "  docs/update-readme"
    echo ""
    exit 1
fi

# ============================================================================
# SUCCESS
# ============================================================================

exit 0
